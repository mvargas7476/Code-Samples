<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template for the git-ignored Secrets.plist.
  1. Copy this file to `Secrets.plist` (same folder).
  2. Replace the placeholder with your own free key from https://www.coinapi.io.
  3. Add Secrets.plist to the ByteCoin app target (Target Membership) so it is bundled.
  Secrets.plist is listed in the repo .gitignore and must never be committed.
-->
<plist version="1.0">
<dict>
	<key>COINAPI_KEY</key>
	<string>YOUR_COINAPI_KEY</string>
</dict>
</plist>
